{
  "name": "tongits",
  "version": "1.0.0",
  "description": "Tong-its local multiplayer game",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:server": "npm run build -w @tongits/server",
    "build:client": "npm run build -w @tongits/client",
    "build": "npm run build:client && npm run build:server",
    "start": "npm run start -w @tongits/server",
    "dev:server": "npm run dev -w @tongits/server",
    "dev:client": "npm run dev -w @tongits/client",
    "dev": "npm run dev:server & npm run dev:client"
  }
}
